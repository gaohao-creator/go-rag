# OpenAI 兼容模型配置
GO_RAG_CHAT_PROVIDER=openai
GO_RAG_CHAT_API_KEY=your_api_key_here
GO_RAG_CHAT_BASE_URL=https://apis.iflow.cn/v1
GO_RAG_CHAT_MODEL=qwen3-max
GO_RAG_CHAT_SYSTEM_PROMPT=你是一个专业的 AI 助手，请基于提供的参考内容回答问题。

# 可选：数据库与服务配置
# GO_RAG_HTTP_PORT=8080
# GO_RAG_DATABASE_DRIVER=mysql
# GO_RAG_DATABASE_DSN=root:abc123@tcp(127.0.0.1:3306)/go_rag?charset=utf8mb4&parseTime=True&loc=Local

# 可选：向量检索配置（默认关闭，开启后走 ES 优先 + DB 降级）
# GO_RAG_VECTOR_ENABLED=false
# GO_RAG_VECTOR_BACKEND=es
# GO_RAG_VECTOR_ADDRESS=http://127.0.0.1:9200
# GO_RAG_VECTOR_USERNAME=
# GO_RAG_VECTOR_PASSWORD=
# GO_RAG_VECTOR_INDEX_PREFIX=rag-
# GO_RAG_VECTOR_CONTENT_FIELD=content
# GO_RAG_VECTOR_CONTENT_VECTOR_FIELD=content_vector
# GO_RAG_VECTOR_QA_CONTENT_FIELD=qa_content
# GO_RAG_VECTOR_QA_CONTENT_VECTOR_FIELD=qa_content_vector
# GO_RAG_VECTOR_KNOWLEDGE_FIELD=_knowledge_name
# GO_RAG_VECTOR_EXT_FIELD=ext
# GO_RAG_VECTOR_DIMENSIONS=1024
# GO_RAG_VECTOR_EMBEDDING_API_KEY=your_api_key_here
# GO_RAG_VECTOR_EMBEDDING_BASE_URL=https://api.openai.com/v1
# GO_RAG_VECTOR_EMBEDDING_MODEL=text-embedding-3-large

# 可选：检索质量链配置
# GO_RAG_QUALITY_QA_ENABLED=false
# GO_RAG_QUALITY_QA_QUESTION_COUNT=3
# GO_RAG_RERANK_ENABLED=false
# GO_RAG_RERANK_BASE_URL=https://your-rerank-service/v1
# GO_RAG_RERANK_API_KEY=your_rerank_api_key_here
# GO_RAG_RERANK_MODEL=bge-reranker-v2-m3
# GO_RAG_RERANK_TOP_N=5
# GO_RAG_RERANK_MIN_SCORE=0
# GO_RAG_QUALITY_GRADER_ENABLED=false
